{
  "version": "0.0.1",
  "autoPort": true,
  "configurations": [
    {
      "name": "tampa-electric-clone",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; p=int(os.environ.get('PORT','4173')); socketserver.TCPServer(('',p), http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "port": 4173
    }
  ]
}
